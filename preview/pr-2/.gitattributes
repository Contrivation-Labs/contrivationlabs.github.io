# Normalize line endings to LF in the repo for all text files
* text=auto eol=lf

# Explicitly LF for web and script files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.py   text eol=lf
*.txt  text eol=lf
*.json text eol=lf

# Binary — do not modify
*.jpg  binary
*.jpeg binary
*.png  binary
*.gif  binary
*.mp4  binary
*.pdf  binary
*.pptx binary
